# Security headers for static asset responses
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: same-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Content-Security-Policy: default-src 'none'; base-uri 'none'; connect-src 'none'; font-src 'self'; form-action 'none'; frame-ancestors 'none'; frame-src 'none'; img-src 'self'; object-src 'none'; script-src 'self' 'sha256-NI6oIC7r5nnULSOQiUB025GmWyKZfFXfhgcRQsPWPKM='; style-src 'self'; upgrade-insecure-requests

# HTML is always revalidated so content updates appear immediately
/index.html
  Cache-Control: public, max-age=0, must-revalidate

/en/*
  Cache-Control: public, max-age=0, must-revalidate

/de/*
  Cache-Control: public, max-age=0, must-revalidate

# Stable CSS and JavaScript names are revalidated
/assets/css/*
  Cache-Control: public, max-age=0, must-revalidate

/assets/js/*
  Cache-Control: public, max-age=0, must-revalidate

# Vendored font files are immutable
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Site metadata and icon
/favicon.svg
  Cache-Control: public, max-age=86400, must-revalidate

/robots.txt
  Cache-Control: public, max-age=3600, must-revalidate

/sitemap.xml
  Cache-Control: public, max-age=3600, must-revalidate
